{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
    "@core/*": ["core/*"],
    "@application/*": ["application/*"],
    "@infrastructure/*": ["infrastructure/*"],
    "@presentation/*": ["presentation/*"],
    "@config/*": ["config/*"]
    },
    
    "target": "esnext",
    "module": "esnext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules"]
}